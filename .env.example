# ElevenLabs Voice
PTV_ELEVENLABS_API_KEY=...
PTV_VOICE_ID=                    # Set after cloning your voice

# Voice Settings
PTV_VOICE_STABILITY=0.5
PTV_VOICE_SIMILARITY_BOOST=0.75
PTV_VOICE_STYLE=0.0
PTV_ELEVENLABS_MODEL=eleven_v3     # eleven_v3, eleven_multilingual_v2, eleven_flash_v2_5
PTV_VOICE_USE_SPEAKER_BOOST=true

# Video Settings
PTV_VIDEO_QUALITY=high           # low, medium, high, 4k
PTV_FRAME_RATE=30
PTV_BACKGROUND_COLOR=#1a1a2e

# Pipeline Settings
PTV_MAX_RENDER_ATTEMPTS=5
PTV_RENDER_TIMEOUT_SECONDS=120
PTV_TARGET_VIDEO_DURATION_MINUTES=10
