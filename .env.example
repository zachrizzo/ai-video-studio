# Voice provider — qwen (bundled local, default), voicebox (Voicebox app), elevenlabs (cloud)
PTV_VOICE_PROVIDER=qwen

# Voicebox voice studio (https://voicebox.sh) — the app must be RUNNING during synthesis.
# Voices/engines are configured as named PROFILES in its UI; pick one by name here.
PTV_VOICEBOX_URL=http://127.0.0.1:17493
PTV_VOICEBOX_PROFILE=Narrator   # a Chatterbox Turbo profile is best for English narration
PTV_VOICEBOX_LANGUAGE=en

# Qwen3-TTS (local fallback)
PTV_QWEN_TTS_SPEAKER=dylan
PTV_QWEN_TTS_LANGUAGE=english

# ElevenLabs Voice
PTV_ELEVENLABS_API_KEY=...
PTV_VOICE_ID=                    # Set after cloning your voice

# Voice Settings
PTV_VOICE_STABILITY=0.5
PTV_VOICE_SIMILARITY_BOOST=0.75
PTV_VOICE_STYLE=0.0
PTV_ELEVENLABS_MODEL=eleven_v3     # eleven_v3, eleven_multilingual_v2, eleven_flash_v2_5
PTV_VOICE_USE_SPEAKER_BOOST=true

# Video Settings
PTV_VIDEO_QUALITY=high           # low, medium, high, 4k
PTV_FRAME_RATE=30
PTV_BACKGROUND_COLOR=#1a1a2e
PTV_VIDEO_SPEED=1.0              # final playback speed, 0.25-4.0 (affects video + audio)

# Pipeline Settings
PTV_MAX_RENDER_ATTEMPTS=5
PTV_RENDER_TIMEOUT_SECONDS=120
PTV_TARGET_VIDEO_DURATION_MINUTES=10
